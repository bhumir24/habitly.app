# ────────────────────────────────────────────────────────────────
# Supabase
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ────────────────────────────────────────────────────────────────
# AI Provider (optional — app runs with mock provider if omitted)
# Supported values: mock | openai | anthropic
# ────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ────────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Force-enable premium features locally without real billing
NEXT_PUBLIC_FORCE_PREMIUM=false

# ────────────────────────────────────────────────────────────────
# Demo login (optional — local / class demos)
# Set DEMO_LOGIN=true after running: npx tsx scripts/ensure-demo-user.ts
# Default credentials: demo@habitly.app / DemoHabitly2026!
# ────────────────────────────────────────────────────────────────
DEMO_LOGIN=false
# DEMO_LOGIN_EMAIL=demo@habitly.app
# DEMO_LOGIN_PASSWORD=DemoHabitly2026!
