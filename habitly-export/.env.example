# ─── PostgreSQL (required for API + Drizzle) ─────────────────────
# Local example (Docker): postgres://postgres:postgres@localhost:5432/habitly
DATABASE_URL=

# ─── API server (@workspace/api-server) ────────────────────────
PORT=8080

# ─── Vite frontend (@workspace/habitly) ─────────────────────────
# Dev server port (must match nothing else on your machine)
# Vite proxies /api → http://localhost:8080 (see vite.config.ts)
VITE_DEV_PORT=5173

# Base path for built assets (use "/" for root hosting)
BASE_PATH=/
